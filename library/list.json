    {
        "title": "Thiên triều đệ nhất đại quốc tuyệt sắc Thái hậu, chim sa cá lặn hoàng hậu cùng đệ nhất mỹ nữ tướng quân vậy mà toàn bộ biến thành địch quốc nội ứng thái giám",
        "slug": "0004",
        "date": "02/06/2026",
        "timestamp": 1780419350.556002,
        "chapters": [
            {
                "id": "000001",
                "name": "Chương 1 Vân quốc Thái hậu, tại nội ứng thái giám đồi Cảnh Vân từng bước một chiến lược phía dưới, cuối cùng bị đặt ở tẩm cung phòng ngủ, bị con cặc lớn của hắn thao  cao trào liên tục",
                "date": "02/06/2026"
            },
            {
                "id": "000002",
                "name": "Chương 2 Tuyệt sắc Thái hậu  dâm đãng sa đọa, tại địch quốc nội ứng thái giám dỏm  đại nhục bổng  bạo thao phía dưới, Thái hậu từ từ biến thành dâm đãng thấp hèn chó cái, thậm chí không để ý đến thân phận quỳ cho hắn liếm côn thịt",
                "date": "02/06/2026"
            },
            {
                "id": "000003",
                "name": "Chương 3 Vân quốc Thái hậu  sa đọa dạy dỗ, quỳ gối địch quốc nằm vùng dưới hông liếm côn thịt uống nước tiểu, thậm chí vì làm hắn vui lòng đi phục dịch đê tiện đổ đêm hương  lão đầu tử",
                "date": "02/06/2026"
            },
            {
                "id": "000004",
                "name": "Chương 4 Thái hậu  triệt để sa đọa, tại biết nội ứng cừu địch  thân phận sau vẫn như cũ lựa chọn quỳ xuống đất nhận chủ, thậm chí mang theo địch nhân đến hoàng cung từ đường  tất cả tiên đế  trước bài vị bên trong xạ cao trào",
                "date": "02/06/2026"
            },
            {
                "id": "000005",
                "name": "Chương 5 Thái hậu trợ giúp địch quốc nội ứng dạy dỗ bổn quốc hoàng hậu, đồi Cảnh Vân trực tiếp tại Phật tượng trước đại điện bạo thao hoàng hậu gì Thục Vân",
                "date": "02/06/2026"
            },
            {
                "id": "000006",
                "name": "Chương 6 Hoàng hậu  sa đọa, lựa chọn phản bội vân quốc, đem vân quốc cần hàng quân nhu cùng tiền tài trực tiếp đưa cho địch quốc quân đội tới tiến đánh quốc gia của mình",
                "date": "02/06/2026"
            },
            {
                "id": "000007",
                "name": "Chương 7 hướng đệ nhất đại quốc  tuyệt sắc Thái hậu, chim sa cá lặn  hoàng hậu cùng đệ nhất mỹ nữ tướng quân vậy mà toàn bộ biến thành địch quốc nội ứng thái giám dỏm dưới quần công cụ tình dục, vì lấy lòng đại kê ba cuối cùng nhao nhao lựa chọn phản quốc",
                "date": "02/06/2026"
            }
